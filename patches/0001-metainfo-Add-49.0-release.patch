From e1c20dd04c96dcdb6746db4993b147214a561bad Mon Sep 17 00:00:00 2001
From: Maximiliano Sandoval <msandova@gnome.org>
Date: Mon, 15 Sep 2025 19:42:37 +0200
Subject: [PATCH] metainfo: Add 49.0 release

Otherwise we get a critical when opening the about dialog.

(gnome-calendar:2): Adwaita-CRITICAL **: 19:12:09.803: No valid release found for version 49.0

Fixes: https://gitlab.gnome.org/GNOME/gnome-calendar/-/issues/1471
Signed-off-by: Maximiliano Sandoval <msandova@gnome.org>
---
 src/appdata/org.gnome.Calendar.metainfo.xml.in.in | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/appdata/org.gnome.Calendar.metainfo.xml.in.in b/src/appdata/org.gnome.Calendar.metainfo.xml.in.in
index c9f58308..a7149050 100644
--- a/src/appdata/org.gnome.Calendar.metainfo.xml.in.in
+++ b/src/appdata/org.gnome.Calendar.metainfo.xml.in.in
@@ -86,7 +86,8 @@
 
   <releases>
 
-    <release date="2025-09-14" version="49.0.1" type="stable">
+    <release date="2025-09-14" version="49.0.1" type="stable" />
+    <release date="2025-09-14" version="49.0" type="stable">
       <description>
         <ul>
           <li>Redesign the main window to show the full calendar view, make the sidebar hideable, move navigation buttons to the bottom, and make the main window adaptative</li>
-- 
2.51.0

